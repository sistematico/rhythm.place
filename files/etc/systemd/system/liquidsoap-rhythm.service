[Unit]
Description=Liquidsoap daemon
After=network.target icecast2-rhythm.service
Documentation=http://liquidsoap.fm

[Service]
Type=simple
User=liquidsoap
ExecStart=/usr/bin/liquidsoap /etc/liquidsoap/rhythm.liq
ExecReload=/usr/bin/kill -HUP $MAINPID
ExecStop=/usr/bin/kill -HUP $MAINPID
#Restart=on-failure
#RestartSec=10s
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
