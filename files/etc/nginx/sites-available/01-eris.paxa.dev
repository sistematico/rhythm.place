server {
    listen 80;
    listen [::]:80;
    server_name eris.paxa.dev;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;

    ssl_certificate         /etc/letsencrypt/live/eris.paxa.dev/fullchain.pem;
    ssl_certificate_key     /etc/letsencrypt/live/eris.paxa.dev/privkey.pem;

    server_name eris.paxa.dev;
    root /var/www/eris.paxa.dev;
    
    include conf.d/cache.conf;
    include conf.d/eris-errors.conf;

    location / {
        try_files $uri $uri/ =404;
    }
}
